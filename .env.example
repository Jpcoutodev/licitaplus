# Copie para .env.local e preencha com os valores do seu projeto Supabase
# (Dashboard -> Settings -> API). Apenas chaves públicas aqui — a service role
# key NUNCA entra no frontend.
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key

# URL canônica do site (SEO: canonical, sitemap, Open Graph).
NEXT_PUBLIC_SITE_URL=https://sentinelagov.com

# Stripe (Vercel, server-side — nunca no cliente)
STRIPE_SECRET_KEY=
STRIPE_PRICE_ESSENCIAL=
STRIPE_PRICE_PROFISSIONAL=
